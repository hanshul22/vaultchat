{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node",
      "target": "es2022",
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "strictPropertyInitialization": false,
      "skipLibCheck": true,
      "resolveJsonModule": true
    }
  }