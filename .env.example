# ─────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────
# Database (Neon Postgres) — use the DIRECT endpoint, not
# ─────────────────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=

# ─────────────────────────────────────────────────
# Redis (Upstash) — native protocol, not REST
# ─────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=true

# ─────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long-different
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ─────────────────────────────────────────────────────
# Encryption (AES-256-GCM for Cloudinary secrets)
# ─────────────────────────────────────────────────────
AES_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────────────

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=
MAIL_FROM=
MAIL_API_KEY=   