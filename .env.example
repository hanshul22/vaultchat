# ─────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────
# Database (Neon Postgres) — use the DIRECT endpoint, not
# ─────────────────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=

# ─────────────────────────────────────────────────
# Redis (Upstash) — native protocol, not REST
# ─────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=true

# ─────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────
LOG_LEVEL=info

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=
JWT_REFRESH_TTL=